# Hermes Agent
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_UID=1000
HERMES_GID=1000
HERMES_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://127.0.0.1:11436

# Discord gateway
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=

# Local monitoring ports. These bind to 127.0.0.1 only.
MONITOR_PROXY_PORT=8080
HERMES_DASHBOARD_PORT=9119
UPTIME_KUMA_PORT=3001
DOZZLE_PORT=9999
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=7d

# Tailscale Serve target metadata for runbooks/scripts.
TAILSCALE_HOSTNAME=hermes-dashboard

# Grafana is optional and only used with the monitoring-full profile.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=
